rules_version = '2';

// Production rules (replaces expired Firebase "Test mode" — time-limited open access).
// Client access requires Firebase Auth + a matching `users/{uid}` profile (same idea as Firestore).
// Use path prefixes when you add uploads: users/{uid}/..., schools/{schoolId}/..., students/{studentId}/...

service firebase.storage {
  match /b/{bucket}/o {

    function userDocPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return request.auth != null && firestore.exists(userDocPath());
    }

    function userData() {
      return firestore.get(userDocPath()).data;
    }

    function isSuperAdmin() {
      return userExists() && userData().role == 'super_admin';
    }

    function isJurisdictionOversight() {
      return userExists() &&
        (userData().role == 'org_admin' || userData().role == 'school_admin' || userData().role == 'district' || userData().role == 'sen_coordinator');
    }

    function userSchoolId() {
      return userData().schoolId;
    }

    function userOrganizationId() {
      return (userData().organizationId is string && userData().organizationId != '') ? userData().organizationId : userData().districtId;
    }

    function schoolOrganizationId(schoolId) {
      let d = firestore.get(/databases/(default)/documents/schools/$(schoolId)).data;
      return (d.organizationId is string && d.organizationId != '') ? d.organizationId : d.districtId;
    }

    // Personal scratch / uploads keyed by Auth uid (mirrors Firestore `users/{uid}` ownership).
    match /users/{userId}/{allPaths=**} {
      allow read, write: if userExists() && request.auth.uid == userId;
    }

    // Shared school assets (worksheets, exports, etc.) — same school or school-admin / SEN jurisdiction.
    match /schools/{schoolId}/{allPaths=**} {
      allow read, write: if userExists() && (
        isSuperAdmin() ||
        (userSchoolId() == schoolId) ||
        (isJurisdictionOversight() &&
          firestore.exists(/databases/(default)/documents/schools/$(schoolId)) &&
          schoolOrganizationId(schoolId) == userOrganizationId())
      );
    }

    // Student portal session: only that learner’s folder, with token check (aligned with Firestore portal rules).
    match /students/{studentId}/{allPaths=**} {
      allow read, write: if userExists() &&
        userData().role == 'student_portal' &&
        studentId == userData().portalStudentId &&
        firestore.exists(/databases/(default)/documents/students/$(studentId)) &&
        firestore.get(/databases/(default)/documents/students/$(studentId)).data.portalSessionToken
          == userData().portalSessionToken;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
