{
  "name": "basecamp-diagnostics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && firebase deploy",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "gen:english-g2": "node scripts/merge-english-g2-ndjson.mjs",
    "gen:english-g3": "node scripts/merge-english-g3-ndjson.mjs",
    "backfill:security-lookups": "tsx scripts/backfillSecurityLookups.ts",
    "backfill:security-lookups:dry": "tsx scripts/backfillSecurityLookups.ts --dry-run",
    "onboard-pilot": "tsx scripts/onboardPilot.ts",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:functions:showYourWork": "firebase deploy --only functions:onShowYourWorkVideoFinalized",
    "deploy:firestore:pilot": "firebase deploy --only firestore:rules --project basecamp-pilot",
    "deploy:firestore:demo": "firebase deploy --only firestore:rules --project basecamp-diagnostics --config firebase.demo.json",
    "deploy:diagnostics": "npm run build -- --mode diagnostics && firebase deploy --config firebase.demo.json --project basecamp-diagnostics",
    "test:rtdb-load": "tsx scripts/loadTestRtdb.ts"
  },
  "dependencies": {
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "idb-keyval": "^6.2.2",
    "jspdf": "^2.5.2",
    "katex": "^0.16.38",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mp4-muxer": "^5.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^15.12.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
