# Required for AI worksheet analysis
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Required for Auth and Firestore (login, students, assessments)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Callable Cloud Functions region (must match deployed functions, e.g. europe-west1)
# VITE_FIREBASE_FUNCTIONS_REGION=europe-west1

# Managed staff pseudo-email domain (must match Cloud Functions env MANAGED_EMAIL_DOMAIN)
# VITE_MANAGED_EMAIL_DOMAIN=basecamp.internal

# Demo-only: set to "true" on the investor/demo Firebase project to show Seed Demo Data + legacy access-code login.
# Pilot / production builds should omit this or set to "false". Use firestore.rules.demo on the demo project if you still need unauthenticated seed writes.
# VITE_ENABLE_DEMO_SEED=false

# Phase 4 fine-tuning pilot: set to 1 to use the “mock local head” gap-tag system prompt (still Gemini).
# VITE_FT_PILOT_GAP_TAGS=1

# One-off scripts only: path to Firebase service account JSON (see scripts/backfillSecurityLookups.ts).
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/serviceAccount.json
