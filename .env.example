# -----------------------------------------------------------------------------
# Demo / investor site — Firebase project: basecamp-diagnostics (BaseCamp Demo)
# Copy these values into `.env` for local dev against the demo backend, or see
# `.env.diagnostics` (used by `vite build --mode diagnostics` / `deploy:diagnostics`).
# -----------------------------------------------------------------------------

VITE_FIREBASE_API_KEY=AIzaSyC_tEN9h8flYdZMC7ToZLK4dZKIl_uyo-A
VITE_FIREBASE_AUTH_DOMAIN=basecamp-diagnostics.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=basecamp-diagnostics
VITE_FIREBASE_STORAGE_BUCKET=basecamp-diagnostics.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=628829125584
VITE_FIREBASE_APP_ID=1:628829125584:web:5c713fd80914d6cb5897d5
# Optional; same as measurementId in Firebase Console → Project settings → Your apps
# VITE_FIREBASE_MEASUREMENT_ID=G-LSS31SVS45

# Callable Cloud Functions region (must match deployed functions, e.g. europe-west1)
# VITE_FIREBASE_FUNCTIONS_REGION=europe-west1

# Required for AI worksheet analysis
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Managed staff pseudo-email domain (must match Cloud Functions env MANAGED_EMAIL_DOMAIN)
# VITE_MANAGED_EMAIL_DOMAIN=basecamp.internal

# Demo-only: set to "true" to show Seed Demo Data + access-code login (teacher/headteacher emails as codes).
# Builds whose VITE_FIREBASE_PROJECT_ID is basecamp-diagnostics enable this automatically (see src/config/demoMode.ts).
# VITE_ENABLE_DEMO_SEED=false
#
# Firestore: production rules are firestore.rules (basecamp-pilot). Demo seed + access-code login rules are
# firestore.rules.demo — deploy with: npm run deploy:firestore:demo (diagnostics only). Never deploy demo rules to pilot.

# Phase 4 fine-tuning pilot: set to 1 to use the “mock local head” gap-tag system prompt (still Gemini).
# VITE_FT_PILOT_GAP_TAGS=1

# One-off scripts only: path to Firebase service account JSON (see scripts/backfillSecurityLookups.ts).
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/serviceAccount.json

# -----------------------------------------------------------------------------
# Pilot / production — use `.env.production` (basecamp-pilot), not this file.
# `vite build` loads `.env.production` by default. Demo hosting uses `--mode diagnostics` (see `.env.diagnostics`).
# Pilot Console snippet includes measurementId G-NYHD7XFR2E (set in `.env.production` as VITE_FIREBASE_MEASUREMENT_ID).
# -----------------------------------------------------------------------------
