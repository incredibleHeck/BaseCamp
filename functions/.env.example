# ──────────────────────────────────────────────────────────
# Cloud Functions runtime environment variables
# Copy to .env and fill in values for your target project.
# ──────────────────────────────────────────────────────────

# ── Region ──────────────────────────────────────────────
# Default Firebase Functions region. All exports use this.
# FUNCTIONS_REGION=europe-west1

# ── Gemini AI ───────────────────────────────────────────
# API key is managed via Firebase Secrets (defineSecret),
# NOT a plain env var. Set it via:
#   firebase functions:secrets:set GEMINI_API_KEY
# Used by: weeklyParentDigestJob, onShowYourWorkVideoFinalized
#
# Optional model override (defaults to gemini-3-flash-preview):
# GEMINI_MODEL=gemini-3-flash-preview

# ── Storage ─────────────────────────────────────────────
# Pin the Storage trigger to a specific bucket (must match
# VITE_FIREBASE_STORAGE_BUCKET on the web client). For
# production Gen2, set the same variable on the Cloud Run
# service or your deploy pipeline — see DEPLOY.md.
# STORAGE_BUCKET=your-project-id.firebasestorage.app

# ── Managed Email ───────────────────────────────────────
# Domain suffix for auto-generated teacher email addresses
# created by the createSchoolTeacher callable. Must match
# VITE_MANAGED_EMAIL_DOMAIN on the web client.
# MANAGED_EMAIL_DOMAIN=basecamp.internal
